{
  "name": "korinfra",
  "version": "0.1.0",
  "description": "AI-powered AWS FinOps CLI - cost optimization, security scanning, Terraform fixes",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "korinfra": "bin/korinfra.js"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist/",
    "!dist/**/*.map",
    "bin/korinfra.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.10.0"
  },
  "scripts": {
    "prepare": "node scripts/patch-ink-types.mjs",
    "build": "tsdown",
    "postbuild": "node --input-type=module -e \"import{cpSync,existsSync}from 'node:fs';if(existsSync('src/storage/migrations'))cpSync('src/storage/migrations','dist/storage/migrations',{recursive:true})\"",
    "dev": "tsx --disable-warning=ExperimentalWarning src/index.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench --watch",
    "lint": "eslint src/ tests/ --cache --cache-strategy content --cache-location node_modules/.cache/eslint/",
    "lint:fix": "eslint src/ tests/ --fix --cache --cache-strategy content --cache-location node_modules/.cache/eslint/",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\"",
    "typecheck": "tsc --noEmit",
    "check": "run-s lint:md && run-p --max-parallel 2 typecheck lint test",
    "compile": "tsx scripts/compile.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint:secrets": "secretlint \"**/*\"",
    "lint:lockfile": "lockfile-lint --path package-lock.json --type npm --allowed-hosts npm --validate-https --validate-integrity",
    "lint:knip": "knip"
  },
  "keywords": [
    "aws",
    "finops",
    "cost-optimization",
    "terraform",
    "security",
    "ai-agent",
    "cli",
    "mcp"
  ],
  "author": "Vladimir Mocanu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/korinfra/korinfra.git"
  },
  "bugs": {
    "url": "https://github.com/korinfra/korinfra/issues"
  },
  "homepage": "https://github.com/korinfra/korinfra#readme",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.138",
    "@anthropic-ai/sdk": "^0.95.2",
    "@aws-sdk/client-cloudtrail": "^3.1048.0",
    "@aws-sdk/client-cloudwatch": "^3.1048.0",
    "@aws-sdk/client-cost-explorer": "^3.1048.0",
    "@aws-sdk/client-dynamodb": "^3.1048.0",
    "@aws-sdk/client-ec2": "^3.1048.0",
    "@aws-sdk/client-ecs": "^3.1048.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1048.0",
    "@aws-sdk/client-elasticache": "^3.1048.0",
    "@aws-sdk/client-lambda": "^3.1048.0",
    "@aws-sdk/client-pricing": "^3.1048.0",
    "@aws-sdk/client-rds": "^3.1048.0",
    "@aws-sdk/client-resource-groups-tagging-api": "^3.1048.0",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/client-sts": "^3.1047.0",
    "@aws-sdk/credential-providers": "^3.1048.0",
    "@cdktf/hcl2json": "^0.21.0",
    "@inkjs/ui": "2.0.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@smithy/node-http-handler": "^4.6.1",
    "cosmiconfig": "9.0.1",
    "gradient-string": "^3.0.0",
    "ink": "7.0.2",
    "ink-spinner": "^5.0.0",
    "js-yaml": "4.1.1",
    "p-limit": "7.3.0",
    "p-throttle": "8.1.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "react": "^19.2.6",
    "string-width": "^8.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/types": "^3.973.8",
    "@eslint/js": "10.0.1",
    "@secretlint/secretlint-rule-aws": "^13.0.0",
    "@secretlint/secretlint-rule-gcp": "^13.0.0",
    "@secretlint/secretlint-rule-no-dotenv": "^13.0.0",
    "@secretlint/secretlint-rule-npm": "^13.0.0",
    "@secretlint/secretlint-rule-privatekey": "^13.0.0",
    "@types/gradient-string": "^1.1.6",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^25.6.2",
    "@types/react": "19.2.14",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.8.0",
    "ink-testing-library": "^4.0.0",
    "knip": "^6.12.2",
    "lockfile-lint": "^5.0.0",
    "markdownlint-cli2": "^0.22.1",
    "npm-run-all2": "^8.0.4",
    "secretlint": "^13.0.0",
    "tsdown": "^0.22.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2",
    "unrun": "^0.3.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@anthropic-ai/claude-agent-sdk": {
      "@anthropic-ai/sdk": "^0.95.2"
    }
  }
}
