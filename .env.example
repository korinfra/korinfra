# korinfra Example Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit actual credentials to version control.

# ─────────────────────────────────────────────────────────────────────────────
# Claude API Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Claude API key — required for all AI-powered features (scan, recommend, etc.)
# Get it at: https://console.anthropic.com/account/keys
# Format: sk-ant-... (exactly 90 characters)
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────────────
# AWS Credentials
# ─────────────────────────────────────────────────────────────────────────────

# AWS Access Key ID — optional if using AWS profiles or instance metadata
# Format: AKIA... (20 characters)
# NEVER commit real credentials. Use IAM roles when possible.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# AWS Secret Access Key — must be paired with AWS_ACCESS_KEY_ID
# Format: wJalr... (40 characters)
# NEVER commit real credentials. Use IAM roles when possible.
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# AWS Session Token — optional, used only for temporary STS credentials
# Leave empty if using long-lived IAM keys or AWS profiles
AWS_SESSION_TOKEN=

# AWS Profile — optional, read from ~/.aws/config or ~/.aws/credentials
# If set, this overrides AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY
# AWS_PROFILE=my-profile

# AWS Region — optional, defaults to us-east-1
# Format: us-west-2, eu-west-1, ap-southeast-1, etc.
# AWS_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Configuration (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# GitHub personal access token — required only for PR creation feature
# Scope: repo:write (or fine-grained token with write access to pull requests)
# Get it at: https://github.com/settings/tokens
# Format: ghp_... (typically 36+ characters)
# NEVER commit real tokens.
GITHUB_TOKEN=ghp_...

# ─────────────────────────────────────────────────────────────────────────────
# MCP Server Configuration (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# MCP HTTP server authentication token (HTTP transport only)
# - If unset: korinfra auto-generates a 32-byte hex token on first start
#   and persists it to ~/.korinfra/mcp-token (mode 0600). Subsequent
#   restarts reload that file, so the token is stable across restarts.
# - Set to a stable 32+ character value to inject your own token (for
#   example from a secret manager) and skip auto-generation entirely.
# - Used with: korinfra serve --http --port 3000
# - Transport is plain HTTP (no TLS) — token and payloads travel in plaintext.
#   Use an SSH tunnel or a TLS-terminating reverse proxy for remote access.
# - Format: any 32+ character hex or alphanumeric string
MCP_AUTH_TOKEN=

# Require MCP_AUTH_TOKEN to be explicitly set for the HTTP transport
# - When 1: korinfra refuses to start unless MCP_AUTH_TOKEN is set, exiting
#   immediately with a fatal error. No auto-generation, no persisted token.
#   Use in production where the token must come from a secret manager.
# - When 0 (default): if MCP_AUTH_TOKEN is unset, korinfra auto-generates
#   and persists a token (see MCP_AUTH_TOKEN above). Convenient for local
#   and development use.
# - Does not apply to the stdio transport (stdio has no token auth).
# MCP_HTTP_REQUIRE_TOKEN=0

# ─────────────────────────────────────────────────────────────────────────────
# Logging (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Log level: debug, info, warn, error
# Default: info
# LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Proxy Configuration (NOT SUPPORTED IN .env)
# ─────────────────────────────────────────────────────────────────────────────

# Proxy settings MUST be configured at the OS or shell level, NOT in .env.
# This prevents accidental MITM attacks via misconfigured proxies.
#
# To use a corporate proxy:
#   export HTTP_PROXY=http://proxy.corp.com:8080
#   export HTTPS_PROXY=https://proxy.corp.com:8080
#   korinfra scan
#
# OR (Windows):
#   set HTTP_PROXY=http://proxy.corp.com:8080
#   set HTTPS_PROXY=https://proxy.corp.com:8080
#   korinfra scan
